---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';
import '../styles/main.css';
import pluginsData from '../data/plugins.json';
import skillsData from '../data/skills.json';

const base = import.meta.env.BASE_URL;
const pluginCount = pluginsData.length;
const agentCount = pluginsData.reduce((sum, p) => sum + p.agents, 0);
const skillCount = skillsData.length;

const philosophy = [
  { title: "Code does code work. AI does AI work.", desc: "Static analysis, regex, and AST for detection. LLMs only for synthesis and judgment. 77% fewer tokens than multi-agent approaches." },
  { title: "One agent, one job, done well", desc: `${agentCount} specialized agents, each with a narrow scope and clear success criteria. No agent tries to do everything.` },
  { title: "Pipeline with gates", desc: "Each step must pass before the next begins. Can't push before review. Can't merge before CI. Hooks enforce it." },
  { title: "Validate plan and results, not every step", desc: "Approve the plan. See the results. The middle is automated. One approval unlocks autonomous execution." },
  { title: "Right model for the task", desc: "Opus for complex reasoning. Sonnet for validation. Haiku for mechanical execution. Quality compounds - early phases deserve the best model." },
  { title: "Composable, not monolithic", desc: "Every command works standalone. /deslop cleans code without /next-task. /ship merges PRs without the full workflow. Pieces compose but each piece is useful on its own." },
];

const stats = [
  { value: "18", label: "Repos" },
  { value: String(pluginCount), label: "Plugins" },
  { value: String(agentCount), label: "Agents" },
  { value: String(skillCount), label: "Skills" },
  { value: "399", label: "Lint Rules" },
];
---
<Base title="agent-sh - Modular tools for AI-powered development">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="hero" id="hero">
      <div class="hero__inner">
        <div class="hero__badge reveal" data-delay="0">{pluginCount} repos &middot; {pluginCount} plugins &middot; {agentCount} agents &middot; {skillCount} skills</div>
        <h1 class="hero__title reveal" data-delay="100">
          <span class="text-gradient">Code does code work.</span><br>AI does AI work.
        </h1>
        <p class="hero__subtitle reveal" data-delay="200">
          The ecosystem for AI agent tooling. Workflow orchestration, config linting, browser automation — each tool standalone, all composable.
        </p>
        <div class="hero__ctas reveal" data-delay="300">
          <a href="#install" class="btn btn--primary">Get Started</a>
          <a href="https://github.com/agent-sh" class="btn btn--ghost" target="_blank" rel="noopener noreferrer">View on GitHub</a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats" id="stats">
      <div class="stats__inner">
        {stats.map(s => (
          <div class="stats__item">
            <span class="stats__number">{s.value}</span>
            <span class="stats__label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Products -->
    <section class="products" id="products">
      <div class="products__inner">
        <div class="section-header">
          <h2 class="section-title reveal" data-delay="0">Three Products</h2>
          <p class="section-subtitle reveal" data-delay="100">Each product solves a different problem. Together they cover the full AI development lifecycle.</p>
        </div>
        <div class="products__grid">
          <a href="https://agent-sh.github.io/agentsys/" class="product-card reveal" data-delay="0" target="_blank" rel="noopener noreferrer">
            <span class="product-card__badge product-card__badge--flagship">Flagship</span>
            <div class="product-card__name">agentsys</div>
            <p class="product-card__desc">Agent runtime and orchestration system. {pluginCount} plugins, {agentCount} agents, {skillCount} skills. Task to merged PR with one plan approval.</p>
            <span class="product-card__stat">12 commands &middot; 3 platforms &middot; 6 languages</span>
            <div class="product-card__install">
              <code>npm install -g agentsys</code>
              <button class="copy-btn" data-code="npm install -g agentsys" aria-label="Copy install command">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25v-7.5z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25v-7.5zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25h-7.5z"/></svg>
              </button>
            </div>
          </a>
          <a href="https://agent-sh.github.io/agnix/" class="product-card reveal" data-delay="100" target="_blank" rel="noopener noreferrer">
            <span class="product-card__badge product-card__badge--tool">Tool</span>
            <div class="product-card__name">agnix</div>
            <p class="product-card__desc">Agent config linter. 399 validation rules across 10+ AI tools. SARIF output for GitHub Code Scanning integration.</p>
            <span class="product-card__stat">399 rules &middot; 10+ tools &middot; SARIF output</span>
            <div class="product-card__install">
              <code>npx agnix .</code>
              <button class="copy-btn" data-code="npx agnix ." aria-label="Copy install command">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25v-7.5z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25v-7.5zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25h-7.5z"/></svg>
              </button>
            </div>
          </a>
          <a href="https://github.com/agent-sh/web-ctl" class="product-card reveal" data-delay="200" target="_blank" rel="noopener noreferrer">
            <span class="product-card__badge product-card__badge--tool">Tool</span>
            <div class="product-card__name">web-ctl</div>
            <p class="product-card__desc">Browser automation and web testing toolkit for AI agents. Headless browser control, authentication, and page interaction.</p>
            <span class="product-card__stat">1 agent &middot; 2 skills &middot; Playwright-based</span>
            <div class="product-card__install">
              <code>agentsys install web-ctl</code>
              <button class="copy-btn" data-code="agentsys install web-ctl" aria-label="Copy install command">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25v-7.5z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25v-7.5zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25h-7.5z"/></svg>
              </button>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Get Started -->
    <section class="quick-start" id="install">
      <div class="quick-start__inner">
        <div class="section-header">
          <h2 class="section-title reveal" data-delay="0">Get Started</h2>
          <p class="section-subtitle reveal" data-delay="100">Pick a tool. Install in one command.</p>
        </div>
        <div class="quick-start__tabs reveal" data-delay="100">
          <button class="quick-start__tab quick-start__tab--active" data-tab="agentsys">agentsys</button>
          <button class="quick-start__tab" data-tab="agnix">agnix</button>
          <button class="quick-start__tab" data-tab="webctl">web-ctl</button>
        </div>
        <div class="quick-start__panel quick-start__panel--active" data-panel="agentsys">
          <p class="quick-start__desc">Workflow orchestration - {pluginCount} plugins, {agentCount} agents, {skillCount} skills.</p>
          <div class="code-block">
            <button class="copy-btn" data-code="npm install -g agentsys && agentsys" aria-label="Copy code">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25v-7.5z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25v-7.5zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25h-7.5z"/></svg>
            </button>
            <pre><span class="prompt">$</span> npm install -g agentsys && agentsys</pre>
          </div>
          <p class="quick-start__alt">Or in Claude Code: <code>/plugin marketplace add agent-sh/agentsys</code></p>
        </div>
        <div class="quick-start__panel" data-panel="agnix">
          <p class="quick-start__desc">Agent config linter - 399 rules across 10+ AI tools.</p>
          <div class="code-block">
            <button class="copy-btn" data-code="npx agnix ." aria-label="Copy code">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25v-7.5z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25v-7.5zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25h-7.5z"/></svg>
            </button>
            <pre><span class="prompt">$</span> npx agnix .</pre>
          </div>
          <p class="quick-start__alt">Also: <code>cargo install agnix</code> or <code>brew install agent-sh/agnix/agnix</code></p>
        </div>
        <div class="quick-start__panel" data-panel="webctl">
          <p class="quick-start__desc">Browser automation for AI agents - Playwright-based, no MCP overhead.</p>
          <div class="code-block">
            <button class="copy-btn" data-code="agentsys install web-ctl" aria-label="Copy code">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25v-7.5z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25v-7.5zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25h-7.5z"/></svg>
            </button>
            <pre><span class="prompt">$</span> agentsys install web-ctl</pre>
          </div>
          <p class="quick-start__alt">Skills: <code>web-browse</code> (headless navigation) and <code>web-auth</code> (login handoff)</p>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="philosophy" id="philosophy">
      <div class="philosophy__inner">
        <div class="section-header">
          <h2 class="section-title reveal" data-delay="0">Built Different</h2>
          <p class="section-subtitle reveal" data-delay="100">Not another AI wrapper. Engineering-grade workflow automation.</p>
        </div>
        <div class="philosophy__grid">
          {philosophy.map((p, i) => (
            <div class="philosophy__card reveal" data-delay={String(i * 80)}>
              <h3 class="philosophy__card-title">{p.title}</h3>
              <p class="philosophy__card-desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    // Tab switching for quick-start
    document.querySelectorAll('.quick-start__tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;
        document.querySelectorAll('.quick-start__tab').forEach(t => t.classList.remove('quick-start__tab--active'));
        document.querySelectorAll('.quick-start__panel').forEach(p => p.classList.remove('quick-start__panel--active'));
        tab.classList.add('quick-start__tab--active');
        document.querySelector(`[data-panel="${target}"]`)?.classList.add('quick-start__panel--active');
      });
    });
  </script>
</Base>
